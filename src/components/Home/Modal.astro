---
import ImageSlider from "../Projects/ImageSlider.astro";

// Modal.astro
---

<div
  id="modal-overlay"
  class="fixed inset-0 backdrop-blur-sm z-50 hidden items-center justify-center p-4"
>
  <div
    id="modal-content"
    class="bg-white rounded-xl shadow-2xl max-w-5xl w-full max-h-[90vh] overflow-y-auto"
  >
    <div class="p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 id="modal-title" class="text-xl font-semibold text-gray-900">
          Modal Title
        </h2>
        <button
          id="modal-close"
          class="text-gray-400 hover:text-gray-600 transition-colors"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- El ImageSlider siempre está presente -->
      <div id="modal-image-slider" class="mb-4">
        <ImageSlider />
      </div>

      <!-- Contenido adicional opcional -->
      <div id="modal-body" class="text-gray-600">
        <!-- Contenido adicional se insertará aquí -->
      </div>
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  interface ModalOptions {
    title?: string;
    content?: string;
    images?: string[];
    onClose?: () => void;
  }

  class Modal {
    private overlay: HTMLElement;
    private content: HTMLElement;
    private title: HTMLElement;
    private body: HTMLElement;
    private imageSliderContainer: HTMLElement;
    private closeBtn: HTMLElement;
    private isOpen = false;

    constructor() {
      this.overlay = document.getElementById("modal-overlay")!;
      this.content = document.getElementById("modal-content")!;
      this.title = document.getElementById("modal-title")!;
      this.body = document.getElementById("modal-body")!;
      this.imageSliderContainer =
        document.getElementById("modal-image-slider")!;
      this.closeBtn = document.getElementById("modal-close")!;

      this.init();
    }

    private init(): void {
      this.closeBtn.addEventListener("click", () => this.close());
      this.overlay.addEventListener("click", (e) => {
        if (e.target === this.overlay) this.close();
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && this.isOpen) this.close();
      });
    }

    open(options: ModalOptions = {}): void {
      if (this.isOpen) return;

      this.isOpen = true;

      // Establecer título
      if (options.title) {
        this.title.textContent = options.title;
      }

      // Manejar contenido adicional
      if (options.content) {
        this.body.innerHTML = options.content;
      } else {
        this.body.innerHTML = "";
      }

      // Configurar el ImageSlider si hay imágenes
      if (options.images && options.images.length > 0) {
        // Mostrar el container del ImageSlider
        this.imageSliderContainer.style.display = "block";

        // Configurar las imágenes en el slider
        setTimeout(() => {
          if ((window as any).imageSlider) {
            (window as any).imageSlider.setImages(
              options.images,
              options.title || ""
            );
          }
        }, 100);
      } else {
        // Ocultar el ImageSlider si no hay imágenes
        this.imageSliderContainer.style.display = "none";
      }

      // Mostrar modal con animaciones
      this.overlay.classList.remove("hidden");
      this.overlay.classList.add("flex");

      gsap.fromTo(
        this.overlay,
        { opacity: 0 },
        { opacity: 1, duration: 0.3, ease: "power2.out" }
      );

      gsap.fromTo(
        this.content,
        { scale: 0.7, opacity: 0, y: 50 },
        { scale: 1, opacity: 1, y: 0, duration: 0.4, ease: "back.out(1.7)" }
      );

      document.body.style.overflow = "hidden";
    }

    close(): void {
      if (!this.isOpen) return;

      this.isOpen = false;

      gsap.to(this.content, {
        scale: 0.7,
        opacity: 0,
        y: 50,
        duration: 0.3,
        ease: "power2.in",
      });

      gsap.to(this.overlay, {
        opacity: 0,
        duration: 0.3,
        ease: "power2.in",
        onComplete: () => {
          this.overlay.classList.add("hidden");
          this.overlay.classList.remove("flex");
          document.body.style.overflow = "";

          // Limpiar contenido al cerrar
          this.body.innerHTML = "";
          this.imageSliderContainer.style.display = "block";

          // Ejecutar callback si existe
          if (this.currentOptions && this.currentOptions.onClose) {
            this.currentOptions.onClose();
          }
        },
      });
    }

    private currentOptions: ModalOptions | null = null;

    // Guardar opciones actuales para callback
    setCurrentOptions(options: ModalOptions): void {
      this.currentOptions = options;
    }
  }

  // Inicializar modal globalmente
  const modal = new Modal();

  // Exponer en window para uso global
  (window as any).openModal = (options?: ModalOptions) => {
    modal.setCurrentOptions(options || {});
    modal.open(options);
  };
  (window as any).closeModal = () => modal.close();
</script>
