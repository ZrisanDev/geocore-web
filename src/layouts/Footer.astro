---
import { Image } from "astro:assets";
import Logo from "../assets/images/logo/logo.webp";

// Obtener el año actual de forma dinámica
const currentYear = new Date().getFullYear();
---

<footer class="bg-black/90 border-t border-gray-200" id="footer">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
      <!-- Company Info -->
      <div class="col-span-1 lg:col-span-2 footer-company">
        <div class="mb-4 footer-logo">
          <Image
            src={Logo}
            width={1000}
            height={1000}
            alt="Geocore Ingenieros Logo"
            class="h-10 w-auto md:h-12"
          />
        </div>
        <h2
          class="text-2xl md:text-3xl font-bold text-gray-100 mb-2 footer-title"
        >
          Geocore Ingenieros
        </h2>
        <h3
          class="text-xl md:text-2xl font-bold text-gray-100 mb-4 footer-subtitle"
        >
          Consultoría Geotécnica Especializada
        </h3>
        <p class="text-gray-400 max-w-md mb-4 footer-description">
          Más de 13 años de experiencia en servicios geotécnicos especializados
          para minería y construcción. Líderes en investigaciones geotécnicas,
          supervisión CQC/CQA y ensayos de laboratorio.
        </p>
      </div>

      <!-- Services -->
      <div class="col-span-1 footer-services">
        <h4
          class="text-lg font-semibold text-gray-100 mb-4 footer-services-title"
        >
          Servicios Principales
        </h4>
        <ul class="space-y-2 text-sm footer-services-list">
          <li class="footer-service-item">
            <a
              href="/servicios/investigaciones-geotecnicas"
              class="text-gray-400 hover:text-blue-400 transition-colors"
            >
              Investigaciones Geotécnicas
            </a>
          </li>
          <li class="footer-service-item">
            <a
              href="/servicios/ensayos-laboratorio"
              class="text-gray-400 hover:text-blue-400 transition-colors"
            >
              Ensayos de Laboratorio
            </a>
          </li>
          <li class="footer-service-item">
            <a
              href="/servicios/supervision-cqc-cqa"
              class="text-gray-400 hover:text-blue-400 transition-colors"
            >
              Supervisión CQC/CQA
            </a>
          </li>
          <li class="footer-service-item">
            <a
              href="/servicios/mecanica-suelos"
              class="text-gray-400 hover:text-blue-400 transition-colors"
            >
              Mecánica de Suelos
            </a>
          </li>
          <li class="footer-service-item">
            <a
              href="/servicios/mecanica-rocas"
              class="text-gray-400 hover:text-blue-400 transition-colors"
            >
              Mecánica de Rocas
            </a>
          </li>
          <li class="footer-service-item">
            <a
              href="/servicios/geosintéticos"
              class="text-gray-400 hover:text-blue-400 transition-colors"
            >
              Ensayos Geosintéticos
            </a>
          </li>
          <li class="footer-service-item">
            <a
              href="/servicios/capacitaciones"
              class="text-gray-400 hover:text-blue-400 transition-colors"
            >
              Capacitaciones Técnicas
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact Information -->
      <div class="col-span-1 footer-contact">
        <h4
          class="text-lg font-semibold text-gray-100 mb-4 footer-contact-title"
        >
          Contacto
        </h4>
        <div class="space-y-3">
          <!-- Address -->
          <div class="flex items-start footer-contact-item">
            <svg
              class="w-5 h-5 text-gray-600 mt-1 mr-3 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <div>
              <p class="text-sm text-gray-500">Dirección</p>
              <p class="text-gray-100 font-medium text-sm">Lima, Perú</p>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start footer-contact-item">
            <svg
              class="w-5 h-5 text-gray-600 mt-1 mr-3 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            <div>
              <p class="text-sm text-gray-500">Teléfono/WhatsApp</p>
              <a
                href="tel:+51999999999"
                class="text-gray-100 font-medium hover:text-blue-400 transition-colors text-sm"
              >
                +51 999 999 999
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start footer-contact-item">
            <svg
              class="w-5 h-5 text-gray-600 mt-1 mr-3 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0z"
              ></path>
            </svg>
            <div>
              <p class="text-sm text-gray-500">Email</p>
              <a
                href="mailto:info@geocoreingenieros.com"
                class="text-gray-100 font-medium hover:text-blue-400 transition-colors text-sm"
              >
                info@geocoreingenieros.com
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="pt-6 border-t border-gray-700 footer-bottom">
      <div
        class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0"
      >
        <!-- Copyright -->
        <div class="text-center md:text-left footer-copyright">
          <p class="text-gray-500 text-sm">
            © Geocore Ingenieros {currentYear} | Todos los derechos reservados
          </p>
        </div>

        <!-- Footer Links -->
        <div
          class="flex flex-wrap justify-center md:justify-end space-x-6 footer-tagline"
        >
          <p class="text-gray-600 text-xs mt-1">
            Consultoría geotécnica especializada desde 2011
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  // Función que se ejecuta cuando el DOM está listo y GSAP está disponible
  function initFooterAnimations() {
    // Verificar que GSAP y ScrollTrigger estén disponibles
    if (typeof gsap === "undefined" || typeof ScrollTrigger === "undefined") {
      console.warn("GSAP o ScrollTrigger no están disponibles");
      return;
    }

    gsap.registerPlugin(ScrollTrigger);

    // Configurar el estado inicial - todos los elementos ocultos
    gsap.set("#footer", {
      opacity: 0,
    });

    gsap.set([".footer-title", ".footer-subtitle", ".footer-description"], {
      y: 50,
      opacity: 0,
    });

    gsap.set([".footer-services-title", ".footer-contact-title"], {
      y: 30,
      opacity: 0,
    });

    gsap.set(".footer-service-item", {
      x: -30,
      opacity: 0,
    });

    gsap.set(".footer-contact-item", {
      x: 30,
      opacity: 0,
    });

    gsap.set([".footer-copyright", ".footer-tagline"], {
      y: 20,
      opacity: 0,
    });

    // Timeline principal con ScrollTrigger
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#footer",
        start: "top 85%",
        end: "bottom 20%",
        toggleActions: "play none none none",
        // markers: true // Descomenta para debug
      },
    });

    // Animación del footer completo
    tl.to("#footer", {
      opacity: 1,
      duration: 0.5,
      ease: "power2.out",
    })

      // Animación de la información de la empresa
      .to(
        ".footer-logo",
        {
          opacity: 1,
          duration: 0.8,
          ease: "power2.out",
        },
        "-=0.3"
      )

      .to(
        ".footer-title",
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
        },
        "-=0.6"
      )

      .to(
        ".footer-subtitle",
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
        },
        "-=0.5"
      )

      .to(
        ".footer-description",
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power2.out",
        },
        "-=0.4"
      )

      // Animación de títulos de secciones
      .to(
        [".footer-services-title", ".footer-contact-title"],
        {
          y: 0,
          opacity: 1,
          duration: 0.6,
          ease: "power2.out",
          stagger: 0.1,
        },
        "-=0.3"
      )

      // Animación de elementos de servicios
      .to(
        ".footer-service-item",
        {
          x: 0,
          opacity: 1,
          duration: 0.5,
          ease: "power2.out",
          stagger: 0.1,
        },
        "-=0.2"
      )

      // Animación de elementos de contacto
      .to(
        ".footer-contact-item",
        {
          x: 0,
          opacity: 1,
          duration: 0.5,
          ease: "power2.out",
          stagger: 0.1,
        },
        "-=0.3"
      )

      // Animación del footer inferior
      .to(
        [".footer-copyright", ".footer-tagline"],
        {
          y: 0,
          opacity: 1,
          duration: 0.6,
          ease: "power2.out",
          stagger: 0.2,
        },
        "-=0.2"
      );

    // Animación adicional de hover para los enlaces
    const serviceLinks = document.querySelectorAll(
      ".footer-service-item a, .footer-contact-item a"
    );

    serviceLinks.forEach((link) => {
      link.addEventListener("mouseenter", () => {
        gsap.to(link, {
          scale: 1.05,
          duration: 0.2,
          ease: "power2.out",
        });
      });

      link.addEventListener("mouseleave", () => {
        gsap.to(link, {
          scale: 1,
          duration: 0.2,
          ease: "power2.out",
        });
      });
    });

    // Configuración especial para el logo
    const logo = document.querySelector(".footer-logo img");
    if (logo) {
      gsap.set(logo, { transformOrigin: "center center" });
    }
  }

  // Ejecutar cuando el DOM esté listo
  if (document.readyState === "loading") {
    document.addEventListener("astro:page-load", initFooterAnimations);
  } else {
    initFooterAnimations();
  }
</script>
